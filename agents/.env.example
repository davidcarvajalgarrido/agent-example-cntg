# Variables de entorno para el agente de revisión de Pull Requests
# Copia este archivo como .env y rellena los valores

# Token de GitHub con permisos de lectura de PRs y escritura de comentarios/reviews
GITHUB_TOKEN=

# Clave de API de OpenAI
OPENAI_API_KEY=

# Propietario del repositorio de GitHub (usuario u organización)
GITHUB_OWNER=

# Nombre del repositorio de GitHub
GITHUB_REPO=

# Modelo de OpenAI a usar (opcional; por defecto usa el definido en el script)
# Ejemplos: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=
